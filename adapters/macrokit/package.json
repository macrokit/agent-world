{
  "name": "@agentworld/adapter-macrokit",
  "version": "0.1.0",
  "description": "Wrap a Macrokit project as an Agent World agent: macros project to capabilities, the real Macrokit dispatcher serves them, novelty escalates to the market, and purchased capability modules install back into the registry.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
  "scripts": {
    "build": "tsup src/index.ts src/demo.ts --format esm --dts --clean",
    "demo": "node dist/demo.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agentworld/agent": "link:../../core/packages/agent",
    "@agentworld/identity": "link:../../core/packages/identity",
    "@agentworld/protocol": "link:../../core/packages/protocol",
    "@macrokit/authoring": "link:../../../macrokit/core/packages/authoring",
    "@macrokit/runtime": "link:../../../macrokit/core/packages/runtime",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.6.0",
    "tsup": "^8.3.0",
    "vitest": "^2.1.0"
  },
  "engines": { "node": ">=20" }
}
