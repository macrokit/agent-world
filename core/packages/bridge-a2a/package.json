{
  "name": "@agentworld/bridge-a2a",
  "version": "0.1.0",
  "description": "Expose an Agent World agent to A2A clients: AgentCard at /.well-known/agent.json + a message/send JSON-RPC subset (spec 02 Appendix A). Zero deps.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agentworld/agent": "workspace:*",
    "@agentworld/protocol": "workspace:*",
    "@agentworld/identity": "workspace:*"
  },
  "engines": {
    "node": ">=20"
  }
}
